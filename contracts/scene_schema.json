{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scene",
  "description": "Canonical scene representation produced by Phase 1, enriched by Phase 2.",
  "type": "object",
  "required": [
    "scene_id",
    "script_type",
    "time_window",
    "text"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "Unique scene identifier (e.g. scene_001)"
    },
    "script_type": {
      "type": "string",
      "enum": [
        "timestamped_drama",
        "raw_drama",
        "event_schedule",
        "cue_sheet",
        "mixed"
      ],
      "description": "Detected script type"
    },
    "time_window": {
      "type": "object",
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "number",
          "description": "Start time in seconds"
        },
        "end": {
          "type": "number",
          "description": "End time in seconds"
        }
      }
    },
    "text": {
      "type": "string",
      "description": "Raw scene text used for downstream analysis"
    },
    "location": {
      "type": [
        "string",
        "null"
      ],
      "description": "Extracted location or stage area"
    },
    "emotion": {
      "type": [
        "object",
        "null"
      ],
      "description": "Emotion enrichment added by Phase 2",
      "properties": {
        "primary": {
          "type": "string"
        },
        "primary_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "secondary": {
          "type": [
            "string",
            "null"
          ]
        },
        "secondary_confidence": {
          "type": "number"
        },
        "accent": {
          "type": [
            "string",
            "null"
          ]
        },
        "accent_confidence": {
          "type": "number"
        }
      }
    },
    "explicit_lighting": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Verbatim lighting cue matches from the script text"
    },
    "dialogue_lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "character",
          "line"
        ],
        "properties": {
          "character": {
            "type": "string"
          },
          "line": {
            "type": "string"
          }
        }
      },
      "description": "Structured dialogue extracted from the scene text"
    },
    "duration": {
      "type": "number",
      "description": "Duration in seconds"
    }
  },
  "additionalProperties": false
}